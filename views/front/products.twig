{% extends 'layouts/base.twig' %}

{% block content %}
    <!-- 1. Page Header -->
    <section class="mb-10 animate-fade-in">
        <div class="products-hero rounded-3xl p-8 sm:p-12 text-center shadow-lg mx-4 sm:mx-6 lg:mx-8">
            <h1 class="products-hero__title text-4xl sm:text-5xl font-extrabold mb-4 tracking-tight">Semua Produk</h1>
            <p class="products-hero__subtitle text-lg sm:text-xl max-w-2xl mx-auto font-medium">Pilih game atau layanan digital favoritmu dan top up dalam hitungan detik.</p>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {% if databaseError %}
            <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700 shadow-sm">
                Gagal memuat produk dari database: {{ databaseError }}
            </div>
        {% endif %}

        <!-- 2. Search & Category Filters -->
        <div class="sticky top-20 z-40 bg-slate-50/95 backdrop-blur-sm py-4 mb-8 -mx-4 px-4 sm:mx-0 sm:px-0">
            <div class="flex flex-col gap-4">
                <form method="get" action="/products" class="flex flex-col md:flex-row gap-4 items-center justify-between">
                    {% if selectedCategoryId %}
                        <input type="hidden" name="category" value="{{ selectedCategoryId }}">
                    {% endif %}

                    <!-- Search Bar -->
                    <div class="w-full md:w-1/2 relative group">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 group-focus-within:text-sky-500 transition-colors">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input
                            type="text"
                            name="q"
                            value="{{ searchQuery }}"
                            placeholder="Cari kategori atau nama produk..."
                            class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 outline-none transition-all bg-white shadow-sm placeholder-slate-400 text-slate-700"
                        >
                    </div>

                    <div class="flex w-full md:w-auto gap-3">
                        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-sky-500 px-5 py-3 font-semibold text-white shadow-md shadow-sky-500/20 transition-all hover:bg-sky-600">
                            Cari
                        </button>
                        {% if searchQuery or selectedCategoryId %}
                            <a href="/products" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 font-semibold text-slate-600 transition-all hover:border-sky-500 hover:text-sky-500 hover:bg-sky-50">
                                Reset
                            </a>
                        {% endif %}
                    </div>
                </form>

                <!-- Category Pills -->
                <div class="w-full overflow-x-auto pb-2 scrollbar-hide">
                    <div class="flex space-x-2 md:justify-end min-w-max">
                        <a href="{% if searchQuery %}/products?q={{ searchQuery|url_encode }}{% else %}/products{% endif %}" class="px-5 py-2.5 rounded-xl font-medium transition-all {{ selectedCategoryId is empty ? 'bg-sky-500 text-white shadow-md shadow-sky-500/20' : 'bg-white text-slate-600 border border-slate-200 hover:border-sky-500 hover:text-sky-500 hover:bg-sky-50 shadow-sm' }}">
                            Semua
                        </a>
                        {% for filterCategory in filterCategories %}
                            <a href="/products?category={{ filterCategory.id }}{% if searchQuery %}&q={{ searchQuery|url_encode }}{% endif %}" class="px-5 py-2.5 rounded-xl font-medium transition-all {{ selectedCategoryId == filterCategory.id ? 'bg-sky-500 text-white shadow-md shadow-sky-500/20' : 'bg-white text-slate-600 border border-slate-200 hover:border-sky-500 hover:text-sky-500 hover:bg-sky-50 shadow-sm' }}">
                                {{ filterCategory.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>

                <div class="flex flex-col gap-1 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between">
                    <p>
                        Menampilkan <span class="font-semibold text-slate-700">{{ products|length }}</span> produk
                        {% if selectedCategoryId %}sesuai filter kategori{% endif %}
                        {% if searchQuery %}untuk kata kunci "<span class="font-semibold text-slate-700">{{ searchQuery }}</span>"{% endif %}.
                    </p>
                    <p>Gunakan filter di atas untuk mempersempit katalog yang tampil.</p>
                </div>
            </div>
        </div>

        <!-- 3. Public Product Grid -->
        <div class="animate-slide-up" style="animation-delay: 0.1s;">
            {% if products is defined and products|length > 0 %}
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {% for product in products %}
                        <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl transition-all duration-300 group">
                            <div class="h-40 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center text-white text-5xl relative overflow-hidden">
                                {% if product.category_cover %}
                                    <img src="{{ product.category_cover }}" alt="{{ product.category_name }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                {% elseif product.category_icon %}
                                    <img src="{{ product.category_icon }}" alt="{{ product.category_name }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                {% else %}
                                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sky-100 to-cyan-50 text-sky-600">
                                        <span class="text-5xl font-black tracking-wide">
                                            {{ product.category_name|upper|slice(0, 2) }}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="p-5">
                                <div class="flex flex-col items-start mb-2">
                                    <span class="text-xs font-semibold text-sky-500 mb-1">{{ product.category_name }}</span>
                                    <h3 class="font-bold text-slate-900 text-lg line-clamp-1" title="{{ product.item_name }}">{{ product.item_name }}</h3>
                                </div>
                                <div class="flex items-center gap-1 text-sm text-amber-500 mb-4">
                                    <i class="fas fa-star"></i>
                                    <span class="font-semibold text-slate-700">5.0</span>
                                    <span class="text-slate-400">(0)</span>
                                </div>
                                <div class="flex justify-between items-center mt-4 pt-4 border-t border-slate-100">
                                    <span class="text-xl font-bold text-sky-500">Rp {{ product.price|number_format(0, ',', '.') }}</span>
                                    <a href="/product/{{ product.id }}" class="px-4 py-2 bg-sky-50 text-sky-500 font-semibold rounded-lg group-hover:bg-sky-500 group-hover:text-white transition-colors">
                                        Beli
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center py-20 px-4 text-center bg-white rounded-3xl border border-slate-100 shadow-sm">
                    <div class="w-24 h-24 mb-6 rounded-full bg-slate-50 flex items-center justify-center">
                        <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">Yaaah, produk tidak ditemukan.</h3>
                    <p class="text-slate-500 max-w-md mx-auto">Coba cari dengan kata kunci lain atau pilih filter kategori yang berbeda.</p>
                    <a href="/products" class="mt-6 inline-flex px-6 py-2.5 bg-sky-50 text-sky-600 font-medium rounded-xl hover:bg-sky-100 transition-colors">
                        Reset Filter
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Optional: Add styles for hiding scrollbar in category pills -->
    <style>
        .products-hero {
            background: linear-gradient(135deg, #0369a1 0%, #0ea5e9 55%, #38bdf8 100%);
            color: #ffffff;
            border: 1px solid rgba(14, 165, 233, 0.18);
            box-shadow: 0 18px 40px rgba(2, 132, 199, 0.18);
        }

        .products-hero__title {
            color: #ffffff;
            text-shadow: 0 2px 12px rgba(12, 74, 110, 0.28);
        }

        .products-hero__subtitle {
            color: rgba(240, 249, 255, 0.96);
        }

        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
{% endblock %}
