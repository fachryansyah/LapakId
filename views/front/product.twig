{% extends 'layouts/base.twig' %}

{% block content %}
<!-- Include jQuery and SlickJS -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>
<style>
    .slick-prev:before, .slick-next:before {
        color: #0ea5e9;
    }
    .slick-slide img {
        display: block;
        margin: auto;
    }
    .slick-list {
        border-radius: 1rem;
    }
    .main-cover-slider .slick-dots {
        bottom: 10px;
    }
    .main-cover-slider .slick-prev {
        left: 10px;
        z-index: 10;
    }
    .main-cover-slider .slick-next {
        right: 10px;
        z-index: 10;
    }
</style>

<form action="/checkout" method="POST" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
    <!-- Hidden input for product_id since we skip 'Pilih Produk' step -->
    <input type="hidden" name="product_id" value="{{ product.id }}">
    {% if product.items|length > 0 %}
    <input type="hidden" name="product_item_id" value="{{ product.items[0].id }}">
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Left Column: Main Content -->
        <div class="lg:col-span-8 space-y-6">
            
            <!-- Category Banner / Screenshot Info Account -->
            <div class="w-full rounded-2xl overflow-hidden bg-slate-100 shadow-sm">
                {% if product.items|length > 0 and product.items[0].images|length > 0 %}
                    <div class="main-cover-slider">
                        {% for image in product.items[0].images %}
                            <div class="aspect-[21/9] sm:aspect-video w-full outline-none">
                                <img src="{{ image }}" alt="Screenshot Item Produk" class="w-full h-full object-cover">
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="aspect-[21/9] sm:aspect-video w-full">
                        <img src="{{ product.banner_url | default('https://placehold.co/800x400/e2e8f0/64748b?text=Banner+Kategori') }}" alt="Banner {{ product.category_name }}" class="w-full h-full object-cover">
                    </div>
                {% endif %}
            </div>

            <!-- 1. Account Specifications -->
            <div class="bg-white rounded-2xl p-6 shadow-sm">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Spesifikasi Akun</h2>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    <div class="p-4 rounded-xl border border-slate-100 bg-slate-50">
                        <p class="text-xs text-slate-500 mb-1">Durasi / Validity</p>
                        <p class="font-semibold text-slate-800 text-sm">Sesuai Produk</p>
                    </div>
                    <div class="p-4 rounded-xl border border-slate-100 bg-slate-50">
                        <p class="text-xs text-slate-500 mb-1">Tipe Akun</p>
                        <p class="font-semibold text-slate-800 text-sm">Private / Sharing</p>
                    </div>
                    <div class="p-4 rounded-xl border border-slate-100 bg-slate-50">
                        <p class="text-xs text-slate-500 mb-1">Region</p>
                        <p class="font-semibold text-slate-800 text-sm">Global</p>
                    </div>
                    <div class="p-4 rounded-xl border border-slate-100 bg-slate-50">
                        <p class="text-xs text-slate-500 mb-1">Garansi</p>
                        <p class="font-semibold text-slate-800 text-sm">Full Garansi</p>
                    </div>
                </div>
            </div>

            <!-- Options Selection (Form Fields) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm space-y-8">
                <!-- Metode Pembayaran -->
                <div>
                    <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                        <span class="w-6 h-6 rounded-full bg-sky-100 text-sky-600 flex items-center justify-center text-xs font-bold">1</span>
                        Metode Pembayaran
                    </h2>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        <!-- QRIS -->
                        <label class="block cursor-pointer">
                            <input type="radio" name="payment_method" value="qris" class="peer hidden" required>
                            <div class="h-full p-4 rounded-xl border border-slate-200 text-center transition-all duration-200
                                peer-checked:border-sky-500 peer-checked:bg-sky-50 peer-checked:ring-1 peer-checked:ring-sky-500
                                hover:border-sky-300 flex flex-col items-center justify-center gap-2">
                                <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                                </div>
                                <span class="font-medium text-slate-700 text-sm">QRIS</span>
                            </div>
                        </label>
                        <!-- E-Wallet -->
                        <label class="block cursor-pointer">
                            <input type="radio" name="payment_method" value="e_wallet" class="peer hidden">
                            <div class="h-full p-4 rounded-xl border border-slate-200 text-center transition-all duration-200
                                peer-checked:border-sky-500 peer-checked:bg-sky-50 peer-checked:ring-1 peer-checked:ring-sky-500
                                hover:border-sky-300 flex flex-col items-center justify-center gap-2">
                                <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                                </div>
                                <span class="font-medium text-slate-700 text-sm">E-Wallet</span>
                            </div>
                        </label>
                        <!-- Transfer Bank -->
                        <label class="block cursor-pointer">
                            <input type="radio" name="payment_method" value="bank_transfer" class="peer hidden">
                            <div class="h-full p-4 rounded-xl border border-slate-200 text-center transition-all duration-200
                                peer-checked:border-sky-500 peer-checked:bg-sky-50 peer-checked:ring-1 peer-checked:ring-sky-500
                                hover:border-sky-300 flex flex-col items-center justify-center gap-2">
                                <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                                </div>
                                <span class="font-medium text-slate-700 text-sm">Transfer Bank</span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- 3. Description & Terms -->
            <div class="bg-white rounded-2xl p-6 shadow-sm">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Deskripsi & Syarat Ketentuan</h2>
                <div class="prose prose-sm text-slate-600 max-w-none">
                    <p>{{ product.category_description | default('Beli akun premium berkualitas dengan proses instan dan aman.') }}</p>
                    
                    <h3 class="text-slate-800 font-semibold mt-6 mb-2">Metode Pengiriman</h3>
                    <p>Item produk (Email & Password / Kode) akan dikirimkan ke email Anda secara instan setelah pembayaran berhasil dikonfirmasi. Anda juga dapat melihat detail pesanan pada halaman Riwayat Transaksi.</p>

                    <h3 class="text-slate-800 font-semibold mt-6 mb-2">Syarat & Ketentuan Garansi</h3>
                    <ul class="list-disc list-inside space-y-1">
                        <li>Dilarang mengubah password, email, atau detail penagihan akun.</li>
                        <li>Dilarang berbagi akun dengan orang lain (kecuali untuk produk Family Plan).</li>
                        <li>Gunakan 1 profil saja jika membeli produk Shared/Private Profile.</li>
                        <li>Garansi otomatis hangus jika melanggar ketentuan di atas.</li>
                        <li>Proses klaim garansi maksimal 1x24 jam hari kerja dengan melampirkan bukti kendala.</li>
                    </ul>
                </div>
            </div>

        </div>

        <!-- Right Column: Checkout/Action Card (Sticky) -->
        <div class="lg:col-span-4 relative">
            <div class="sticky top-24 space-y-6">
                
                <!-- Category Info -->
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col gap-4 items-center text-center">
                    <div class="w-20 h-20 rounded-2xl overflow-hidden bg-slate-100 shadow-sm flex-shrink-0">
                        <img src="{{ product.icon_url | default('https://placehold.co/100x100/e2e8f0/64748b?text=Icon') }}" alt="Icon {{ product.category_name }}" class="w-full h-full object-cover">
                    </div>
                    <div class="w-full">
                        <div class="flex items-center justify-center gap-2 mb-2 flex-wrap">
                            <span class="px-3 py-1 bg-sky-100 text-sky-600 text-xs font-semibold rounded-full">{{ product.category_name }}</span>
                            <span class="px-3 py-1 bg-emerald-100 text-emerald-600 text-xs font-semibold rounded-full flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                Instant
                            </span>
                        </div>
                        <h1 class="text-xl font-bold text-slate-800 mb-3">{{ product.category_name }} - {{ product.name }}</h1>
                        
                        <!-- Seller Info -->
                        <div class="flex flex-col items-center gap-3 border-t border-slate-100 pt-4 mt-2">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-200 overflow-hidden">
                                    <img src="https://ui-avatars.com/api/?name={{ product.publisher | default('LapakId') }}&background=0ea5e9&color=fff" class="w-full h-full" alt="Seller">
                                </div>
                                <div class="text-left">
                                    <div class="flex items-center gap-1">
                                        <span class="font-medium text-slate-700 text-sm">{{ product.publisher | default('LapakId Official') }}</span>
                                        <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                    </div>
                                    <p class="text-xs text-slate-500">Trusted Seller</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-1.5 bg-slate-50 px-3 py-1.5 rounded-lg w-full justify-center">
                                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                <span class="font-bold text-slate-700 text-sm">5.0</span>
                                <span class="text-slate-400 text-xs">(10k+ Rating)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ringkasan Pesanan -->
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                    <h3 class="text-lg font-bold text-slate-800 mb-4">Ringkasan Pesanan</h3>
                    
                    <div class="space-y-4 mb-6">
                        <div class="flex justify-between items-center pb-4 border-b border-slate-100">
                            <span class="text-slate-500 text-sm">Harga Produk</span>
                            <span class="font-bold text-slate-800" id="summary_price">Rp {{ product.price|number_format(0, ',', '.') }}</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-500 text-sm">Stok Tersedia</span>
                            {% if product.items|length > 0 %}
                                <span class="px-2.5 py-1 bg-emerald-100 text-emerald-700 text-xs font-bold rounded-md">{{ product.items|length }} Item</span>
                            {% else %}
                                <span class="px-2.5 py-1 bg-rose-100 text-rose-700 text-xs font-bold rounded-md">Habis</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="mb-6">
                        <p class="text-sm text-slate-500 mb-1">Total Pembayaran</p>
                        <p class="text-3xl font-bold text-sky-500" id="total_price_display">Rp {{ product.price|number_format(0, ',', '.') }}</p>
                    </div>

                    <div class="space-y-3">
                        {% if currentUser %}
                            <button type="submit" {% if product.items|length == 0 %}disabled{% endif %} class="w-full px-6 py-3.5 bg-sky-500 text-white font-bold rounded-xl shadow-lg shadow-sky-500/30 transition-all duration-300 hover:bg-sky-600 hover:-translate-y-0.5 hover:shadow-sky-500/50 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 disabled:hover:bg-sky-500 disabled:hover:shadow-sky-500/30">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                Beli Sekarang
                            </button>
                            
                            <button type="button" {% if product.items|length == 0 %}disabled{% endif %} class="w-full px-6 py-3.5 bg-white text-sky-500 border-2 border-sky-500 font-bold rounded-xl transition-all duration-300 hover:bg-sky-50 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:border-slate-300 disabled:text-slate-400">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                Add to Cart
                            </button>
                        {% else %}
                            <a href="/login" class="w-full px-6 py-3.5 bg-sky-500 text-white font-bold rounded-xl shadow-lg shadow-sky-500/30 transition-all duration-300 hover:bg-sky-600 hover:-translate-y-0.5 hover:shadow-sky-500/50 flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                                Login untuk Membeli
                            </a>
                        {% endif %}
                    </div>

                    <div class="mt-6 flex items-center justify-center gap-1.5 text-xs text-slate-400">
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        Transaksi 100% Aman & Terlindungi
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</form>

<!-- jQuery and SlickJS Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>
<script>
    $(document).ready(function(){
        // Initialize main cover slider
        {% if product.items|length > 0 and product.items[0].images|length > 0 %}
            $('.main-cover-slider').slick({
                dots: true,
                infinite: true,
                speed: 500,
                fade: true,
                cssEase: 'linear',
                autoplay: true,
                autoplaySpeed: 3000,
                arrows: true
            });
        {% endif %}
    });
</script>
{% endblock %}