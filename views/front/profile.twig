{% extends "layouts/base.twig" %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-8 sm:p-10 border-b border-slate-200">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-full bg-sky-100 text-sky-500 flex items-center justify-center text-2xl font-bold">
                    {{ currentUser.fullname|first|upper }}
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-900">Profil Saya</h1>
                    <p class="text-sm text-slate-500 mt-1">Kelola informasi akun Anda</p>
                </div>
            </div>
        </div>

        <div class="px-6 py-8 sm:p-10">
            {% if error %}
            <div class="mb-6 bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-xl text-sm" role="alert">
                <span class="block sm:inline">{{ error }}</span>
            </div>
            {% endif %}

            <form action="/profile" method="POST" class="space-y-6">
                <div class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-8">
                    <div class="sm:col-span-2">
                        <label for="fullname" class="block text-sm font-medium text-slate-700">Nama Lengkap</label>
                        <div class="mt-1">
                            <input type="text" name="fullname" id="fullname" value="{{ form.fullname }}" required
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm transition-colors">
                        </div>
                    </div>

                    <div class="sm:col-span-2">
                        <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
                        <div class="mt-1">
                            <input type="email" name="email" id="email" value="{{ form.email }}" required
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm transition-colors">
                        </div>
                    </div>

                    <div class="sm:col-span-2 pt-4 border-t border-slate-100">
                        <h3 class="text-lg font-medium text-slate-900 mb-4">Ubah Password</h3>
                        <p class="text-sm text-slate-500 mb-4">Kosongkan jika tidak ingin mengubah password.</p>
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium text-slate-700">Password Baru</label>
                        <div class="mt-1">
                            <input type="password" name="password" id="password"
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm transition-colors"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <div>
                        <label for="password_confirm" class="block text-sm font-medium text-slate-700">Konfirmasi Password Baru</label>
                        <div class="mt-1">
                            <input type="password" name="password_confirm" id="password_confirm"
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm transition-colors"
                                placeholder="••••••••">
                        </div>
                    </div>
                </div>

                <div class="pt-6 flex justify-end">
                    <button type="submit"
                        class="inline-flex justify-center py-3 px-6 border border-transparent shadow-sm text-sm font-medium rounded-xl text-white bg-sky-500 hover:bg-sky-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-500 transition-all">
                        Simpan Perubahan
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}