<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LapakId - Jual & Beli Akun Digital Premium</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased overflow-x-hidden selection:bg-sky-500 selection:text-white">

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <div class="flex-shrink-0 flex items-center">
                    <a href="#" class="text-2xl font-bold text-slate-900">
                        Lapak<span class="text-sky-500">Id</span>
                    </a>
                </div>
                
                <!-- Desktop Menu -->
                <div class="hidden md:flex space-x-8 items-center">
                    <a href="#home" class="text-slate-600 hover:text-sky-500 font-medium transition-colors">Beranda</a>
                    <a href="#categories" class="text-slate-600 hover:text-sky-500 font-medium transition-colors">Kategori</a>
                    <a href="#marketplace" class="text-slate-600 hover:text-sky-500 font-medium transition-colors">Marketplace</a>
                    <a href="#features" class="text-slate-600 hover:text-sky-500 font-medium transition-colors">Kenapa Kami</a>
                </div>

                <!-- Auth Button -->
                <div class="hidden md:flex items-center gap-4">
                    {% if currentUser %}
                        <div class="relative" x-data="{ open: false }">
                            <button @click="open = !open" @click.away="open = false" class="flex items-center gap-2 text-slate-600 hover:text-sky-500 font-medium transition-colors focus:outline-none">
                                <div class="w-8 h-8 rounded-full bg-sky-100 text-sky-500 flex items-center justify-center font-bold">
                                    {{ currentUser.fullname|first|upper }}
                                </div>
                                <span>{{ currentUser.fullname }}</span>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div x-show="open" x-transition style="display: none;" class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-slate-100 py-2 z-50">
                                <a href="/profile" class="block px-4 py-2 text-sm text-slate-700 hover:bg-sky-50 hover:text-sky-500">Profile</a>
                                <a href="/transaction" class="block px-4 py-2 text-sm text-slate-700 hover:bg-sky-50 hover:text-sky-500">Transaction</a>
                                <form action="/logout" method="POST" class="block w-full">
                                    <button type="submit" class="w-full text-left px-4 py-2 text-sm text-rose-600 hover:bg-rose-50">Logout</button>
                                </form>
                            </div>
                        </div>
                    {% else %}
                        <a href="/login" class="bg-sky-500 hover:bg-sky-600 text-white px-6 py-2 rounded-full font-medium transition-all shadow-md hover:shadow-lg">
                            Masuk / Daftar
                        </a>
                    {% endif %}
                </div>

                <!-- Mobile menu button -->
                <div class="md:hidden flex items-center gap-3">
                    {% if currentUser %}
                        <div class="relative" x-data="{ open: false }">
                            <button @click="open = !open" @click.away="open = false" class="flex items-center gap-2 focus:outline-none">
                                <div class="w-8 h-8 rounded-full bg-sky-100 text-sky-500 flex items-center justify-center font-bold">
                                    {{ currentUser.fullname|first|upper }}
                                </div>
                            </button>
                            <div x-show="open" x-transition style="display: none;" class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-slate-100 py-2 z-50">
                                <div class="px-4 py-2 border-b border-slate-100 mb-1">
                                    <p class="text-sm font-medium text-slate-900 truncate">{{ currentUser.fullname }}</p>
                                </div>
                                <a href="/profile" class="block px-4 py-2 text-sm text-slate-700 hover:bg-sky-50 hover:text-sky-500">Profile</a>
                                <a href="/transaction" class="block px-4 py-2 text-sm text-slate-700 hover:bg-sky-50 hover:text-sky-500">Transaction</a>
                                <form action="/logout" method="POST" class="block w-full">
                                    <button type="submit" class="w-full text-left px-4 py-2 text-sm text-rose-600 hover:bg-rose-50">Logout</button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                    <button id="mobile-menu-btn" class="text-slate-600 hover:text-sky-500 focus:outline-none">
                        <i class="fas fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 absolute w-full shadow-lg">
            <div class="px-4 pt-2 pb-4 space-y-1">
                <a href="#home" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-sky-500 hover:bg-sky-50 transition-colors">Beranda</a>
                <a href="#categories" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-sky-500 hover:bg-sky-50 transition-colors">Kategori</a>
                <a href="#marketplace" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-sky-500 hover:bg-sky-50 transition-colors">Marketplace</a>
                <a href="#features" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-sky-500 hover:bg-sky-50 transition-colors">Kenapa Kami</a>
                {% if not currentUser %}
                <a href="/login" class="block px-3 py-2 mt-4 text-center rounded-md text-base font-medium bg-sky-500 text-white hover:bg-sky-600 transition-colors">Masuk / Daftar</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="relative pt-20 pb-24 lg:pt-32 lg:pb-40 bg-slate-50 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                
                <!-- Hero Content -->
                <div data-aos="fade-right">
                    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-6">
                        Jual & Beli Akun Digital <span class="text-sky-500">Premium</span> Secara Instan
                    </h1>
                    <p class="text-lg text-slate-600 mb-8 max-w-lg">
                        Marketplace aman untuk akun game, langganan streaming, dan software premium. Pengiriman instan, perlindungan escrow, dan dukungan 24/7.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#marketplace" class="inline-flex justify-center items-center px-8 py-3.5 bg-sky-500 hover:bg-sky-600 text-white rounded-full font-semibold transition-all shadow-lg hover:shadow-sky-500/30">
                            Mulai Belanja
                        </a>
                        {# <a href="#sell" class="inline-flex justify-center items-center px-8 py-3.5 bg-transparent border-2 border-sky-500 text-sky-500 hover:bg-sky-50 rounded-full font-semibold transition-all">
                            Mulai Jualan
                        </a> #}
                    </div>
                </div>

                <!-- Hero Visuals (Floating Logos Grid) -->
                <div class="relative h-96 lg:h-[500px]" data-aos="fade-left" data-aos-delay="200">
                    <!-- Background Blob -->
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 bg-sky-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-pulse"></div>
                    
                    <!-- Floating Elements -->
                    <div class="absolute top-10 left-10 bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 animate-[bounce_3s_infinite]">
                        <i class="fab fa-netflix text-red-600 text-3xl"></i>
                        <div>
                            <p class="text-sm font-bold text-slate-800">Netflix Premium</p>
                            <p class="text-xs text-green-500 font-semibold">Tersedia</p>
                        </div>
                    </div>

                    <div class="absolute bottom-20 left-4 bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 animate-[bounce_4s_infinite_0.5s]">
                        <i class="fab fa-spotify text-green-500 text-3xl"></i>
                        <div>
                            <p class="text-sm font-bold text-slate-800">Spotify 1 Tahun</p>
                            <p class="text-xs text-sky-500 font-semibold">Promo Hot</p>
                        </div>
                    </div>

                    <div class="absolute top-1/3 right-4 bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 animate-[bounce_3.5s_infinite_1s]">
                        <i class="fas fa-gamepad text-indigo-500 text-3xl"></i>
                        <div>
                            <p class="text-sm font-bold text-slate-800">Valorant Diamond</p>
                            <p class="text-xs text-slate-500">Akun</p>
                        </div>
                    </div>
                    
                    <div class="absolute bottom-10 right-20 bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 animate-[bounce_3s_infinite_1.5s]">
                        <i class="fas fa-robot text-teal-500 text-3xl"></i>
                        <div>
                            <p class="text-sm font-bold text-slate-800">ChatGPT Plus</p>
                            <p class="text-xs text-green-500 font-semibold">Terverifikasi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="py-20 bg-white" id="categories">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16" data-aos="fade-up">
                <h2 class="text-3xl font-bold text-slate-900 mb-4">Jelajahi Kategori</h2>
                <p class="text-slate-600 max-w-2xl mx-auto">Temukan akun digital atau langganan sempurna yang sesuai dengan kebutuhan Anda.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Category 1 -->
                <div class="bg-slate-50 rounded-2xl p-8 text-center hover:bg-sky-50 hover:-translate-y-2 transition-all duration-300 border border-slate-100 hover:border-sky-200 cursor-pointer group" data-aos="zoom-in" data-aos-delay="100">
                    <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm text-sky-500 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fas fa-gamepad"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Akun Game</h3>
                    <p class="text-slate-600 text-sm">Akun Valorant, Genshin Impact, Steam, dan lainnya dengan rank tinggi & item langka.</p>
                </div>

                <!-- Category 2 -->
                <div class="bg-slate-50 rounded-2xl p-8 text-center hover:bg-sky-50 hover:-translate-y-2 transition-all duration-300 border border-slate-100 hover:border-sky-200 cursor-pointer group" data-aos="zoom-in" data-aos-delay="200">
                    <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm text-sky-500 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fas fa-play-circle"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Layanan Streaming</h3>
                    <p class="text-slate-600 text-sm">Langganan Netflix, Spotify, YouTube Premium, dan Disney+ dengan harga terbaik.</p>
                </div>

                <!-- Category 3 -->
                <div class="bg-slate-50 rounded-2xl p-8 text-center hover:bg-sky-50 hover:-translate-y-2 transition-all duration-300 border border-slate-100 hover:border-sky-200 cursor-pointer group" data-aos="zoom-in" data-aos-delay="300">
                    <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm text-sky-500 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fas fa-brain"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Produktivitas & AI</h3>
                    <p class="text-slate-600 text-sm">Lisensi ChatGPT Plus, Canva Pro, Adobe Creative Cloud, dan Microsoft 365.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Accounts (Marketplace Preview) -->
    <section id="marketplace" class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-end mb-12" data-aos="fade-right">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-2">Akun Pilihan</h2>
                    <p class="text-slate-600">Pilihan terbaik yang dikurasi khusus untuk Anda.</p>
                </div>
                <a href="/products" class="hidden sm:inline-flex text-sky-500 font-semibold hover:text-sky-600 transition-colors">Lihat Semua <i class="fas fa-arrow-right ml-2 mt-1"></i></a>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {% for product in products|slice(0, 8) %}
                <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl transition-all duration-300 group" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
                    <div class="h-40 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center text-white text-5xl relative overflow-hidden">
                        {% if product.category_cover %}
                            <img src="{{ product.category_cover }}" alt="{{ product.category_name }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        {% elseif product.category_icon %}
                            <img src="{{ product.category_icon }}" alt="{{ product.category_name }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        {% else %}
                            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sky-100 to-cyan-50 text-sky-600">
                                <span class="text-5xl font-black tracking-wide">
                                    {{ product.category_name|upper|slice(0, 2) }}
                                </span>
                            </div>
                        {% endif %}
                    </div>
                    <div class="p-5">
                        <div class="flex flex-col items-start mb-2">
                            <span class="text-xs font-semibold text-sky-500 mb-1">{{ product.category_name }}</span>
                            <h3 class="font-bold text-slate-900 text-lg line-clamp-1" title="{{ product.item_name }}">{{ product.item_name }}</h3>
                        </div>
                        <div class="flex items-center gap-1 text-sm text-amber-500 mb-4">
                            <i class="fas fa-star"></i>
                            <span class="font-semibold text-slate-700">5.0</span>
                            <span class="text-slate-400">(0)</span>
                        </div>
                        <div class="flex justify-between items-center mt-4 pt-4 border-t border-slate-100">
                            <span class="text-xl font-bold text-sky-500">Rp {{ product.price|number_format(0, ',', '.') }}</span>
                            <a href="/product/{{ product.id }}" class="px-4 py-2 bg-sky-50 text-sky-500 font-semibold rounded-lg group-hover:bg-sky-500 group-hover:text-white transition-colors">
                                Beli
                            </a>
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="col-span-full text-center py-10 text-slate-500">
                    Belum ada produk tersedia.
                </div>
                {% endfor %}
            </div>
            <div class="mt-8 text-center sm:hidden">
                <a href="/products" class="inline-flex text-sky-500 font-semibold hover:text-sky-600 transition-colors">Lihat Semua Marketplace <i class="fas fa-arrow-right ml-2 mt-1"></i></a>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20 bg-white" id="features">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16" data-aos="fade-down">
                <h2 class="text-3xl font-bold text-slate-900 mb-4">Kenapa Memilih LapakId?</h2>
                <p class="text-slate-600 max-w-2xl mx-auto">Kami menyediakan cara teraman dan tercepat untuk bertransaksi aset digital.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <!-- Feature 1 -->
                <div class="text-center" data-aos="fade-right" data-aos-delay="100">
                    <div class="w-20 h-20 mx-auto bg-sky-50 rounded-2xl flex items-center justify-center text-sky-500 text-3xl mb-6 transform rotate-3 hover:rotate-0 transition-transform">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Pengiriman Instan</h3>
                    <p class="text-slate-600">Dapatkan detail akun Anda secara instan setelah pembayaran selesai. Tanpa waktu tunggu, mulai nikmati fitur premium Anda segera.</p>
                </div>

                <!-- Feature 2 -->
                <div class="text-center" data-aos="fade-up" data-aos-delay="200">
                    <div class="w-20 h-20 mx-auto bg-sky-50 rounded-2xl flex items-center justify-center text-sky-500 text-3xl mb-6 transform -rotate-3 hover:rotate-0 transition-transform">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Sistem Rekening Bersama (Escrow)</h3>
                    <p class="text-slate-600">Dana Anda disimpan dengan aman hingga Anda memverifikasi detail akun. Perlindungan 100% terhadap penipuan bagi pembeli dan penjual.</p>
                </div>

                <!-- Feature 3 -->
                <div class="text-center" data-aos="fade-left" data-aos-delay="300">
                    <div class="w-20 h-20 mx-auto bg-sky-50 rounded-2xl flex items-center justify-center text-sky-500 text-3xl mb-6 transform rotate-3 hover:rotate-0 transition-transform">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Dukungan 24/7</h3>
                    <p class="text-slate-600">Tim dukungan kami tersedia setiap saat untuk membantu Anda dengan pertanyaan atau masalah apa pun yang mungkin Anda temui.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <!-- Brand -->
                <div class="flex flex-col items-center md:items-start">
                    <a href="#" class="text-2xl font-bold text-slate-900 mb-2">
                        Lapak<span class="text-sky-500">Id</span>
                    </a>
                    <p class="text-sm text-slate-500 text-center md:text-left max-w-xs">
                        Marketplace terpercaya untuk akun dan langganan digital premium.
                    </p>
                </div>

                <!-- Social Links -->
                <div class="flex gap-4">
                    <a href="#" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 hover:bg-sky-500 hover:text-white transition-colors">
                        <i class="fab fa-twitter"></i>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 hover:bg-sky-500 hover:text-white transition-colors">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 hover:bg-sky-500 hover:text-white transition-colors">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                </div>
            </div>
            
            <div class="mt-8 pt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-500">
                <div>&copy; 2026 LapakId. Hak cipta dilindungi undang-undang.</div>
                <div class="flex gap-6">
                    <a href="#" class="hover:text-sky-500 transition-colors">Syarat & Ketentuan</a>
                    <a href="#" class="hover:text-sky-500 transition-colors">Kebijakan Privasi</a>
                    <a href="#" class="hover:text-sky-500 transition-colors">Hubungi Kami</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- AOS JS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    <!-- Interactive Scripts -->
    <script>
        // AOS Initialization
        AOS.init({
            once: false,
            mirror: true,
            offset: 50,
            duration: 800,
            easing: 'ease-out-cubic'
        });

        // Mobile Menu Toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>
</body>
</html>
