{% extends 'layouts/admin.twig' %}

{% block content %}
<form action="{{ submitUrl }}" method="POST" class="space-y-6">
    {% if errors %}
        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 flex gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
                <p class="font-bold">Mohon perbaiki error validasi berikut:</p>
                <ul class="mt-2 list-disc space-y-1 pl-5">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% if databaseError %}
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>Gagal menyimpan kategori. {{ databaseError }}</p>
        </div>
    {% endif %}

    <section class="ppob-card bg-white rounded-2xl shadow-sm border border-slate-100 p-6 grid gap-6 lg:grid-cols-2">
        <div class="lg:col-span-2 border-b border-slate-100 pb-4">
            <h3 class="text-lg font-bold text-slate-800">Informasi Dasar Kategori</h3>
            <p class="mt-1 text-sm text-slate-500">Isi informasi dasar untuk kategori baru Anda.</p>
        </div>

        <div class="lg:col-span-2">
            <label for="name" class="mb-2 block text-sm font-semibold text-slate-700">Nama Kategori</label>
            <input id="name" name="name" type="text" value="{{ form.name }}" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20" placeholder="Contoh: Mobile Legends" required>
        </div>

        <div class="lg:col-span-2">
            <label for="description" class="mb-2 block text-sm font-semibold text-slate-700">Deskripsi (Opsional)</label>
            <textarea id="description" name="description" rows="4" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20" placeholder="Beli diamond MLBB dengan harga termurah...">{{ form.description }}</textarea>
        </div>
    </section>

    <section class="ppob-card bg-white rounded-2xl shadow-sm border border-slate-100 p-6 grid gap-6 lg:grid-cols-2">
        <div class="lg:col-span-2 border-b border-slate-100 pb-4">
            <h3 class="text-lg font-bold text-slate-800">Media Kategori</h3>
            <p class="mt-1 text-sm text-slate-500">Unggah icon dan cover untuk kategori Anda.</p>
        </div>

        <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700">Icon Kategori</label>
            <input type="hidden" id="icon" name="icon" value="{{ form.icon }}">
            <div class="mt-2 flex items-center gap-4">
                <div id="icon-preview-container" class="h-20 w-20 overflow-hidden rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 flex items-center justify-center relative group">
                    <img id="icon-preview" src="{{ form.icon }}" alt="Icon" class="h-full w-full object-cover {{ form.icon ? '' : 'hidden' }}">
                    <div id="icon-placeholder" class="text-slate-400 {{ form.icon ? 'hidden' : '' }}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                </div>
                <div class="flex-1">
                    <input type="file" id="icon-upload" accept="image/jpeg,image/png,image/webp,image/svg+xml" class="hidden">
                    <label for="icon-upload" class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-medium text-slate-700 border border-slate-200 hover:bg-slate-50 transition-colors shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                        Upload Icon
                    </label>
                    <p class="mt-2 text-xs text-slate-500">PNG, JPG, WEBP, SVG max 2MB. Rasio 1:1 disarankan.</p>
                </div>
            </div>
        </div>

        <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700">Cover Kategori</label>
            <input type="hidden" id="cover" name="cover" value="{{ form.cover }}">
            <div class="mt-2 flex items-center gap-4">
                <div id="cover-preview-container" class="h-24 w-40 overflow-hidden rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 flex items-center justify-center relative group">
                    <img id="cover-preview" src="{{ form.cover }}" alt="Cover" class="h-full w-full object-cover {{ form.cover ? '' : 'hidden' }}">
                    <div id="cover-placeholder" class="text-slate-400 {{ form.cover ? 'hidden' : '' }}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                </div>
                <div class="flex-1">
                    <input type="file" id="cover-upload" accept="image/jpeg,image/png,image/webp,image/svg+xml" class="hidden">
                    <label for="cover-upload" class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-medium text-slate-700 border border-slate-200 hover:bg-slate-50 transition-colors shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                        Upload Cover
                    </label>
                    <p class="mt-2 text-xs text-slate-500">PNG, JPG, WEBP, SVG max 2MB. Rasio banner disarankan.</p>
                </div>
            </div>
        </div>
    </section>

    <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
        <a href="/admin/categories" class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl transition-colors">
            Batal
        </a>
        <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-sky-600 hover:bg-sky-700 rounded-xl transition-colors shadow-sm shadow-sky-600/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
            </svg>
            {{ formMode == 'create' ? 'Simpan Kategori' : 'Perbarui Kategori' }}
        </button>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', () => {
    function setupUploader(inputId, fieldName, previewId, placeholderId, hiddenInputId) {
        const fileInput = document.getElementById(inputId);
        const preview = document.getElementById(previewId);
        const placeholder = document.getElementById(placeholderId);
        const hiddenInput = document.getElementById(hiddenInputId);

        fileInput.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch(`/admin/upload/category/${fieldName}`, {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    preview.src = data.path;
                    preview.classList.remove('hidden');
                    placeholder.classList.add('hidden');
                    hiddenInput.value = data.path;
                } else {
                    alert(data.error || 'Upload failed');
                }
            } catch (err) {
                alert('An error occurred while uploading.');
            }
        });
    }

    setupUploader('icon-upload', 'icon', 'icon-preview', 'icon-placeholder', 'icon');
    setupUploader('cover-upload', 'cover', 'cover-preview', 'cover-placeholder', 'cover');
});
</script>
{% endblock %}