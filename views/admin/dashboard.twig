{% extends 'layouts/admin.twig' %}

{% block content %}
{% if databaseError %}
    <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
        <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>Gagal memuat data dashboard. {{ databaseError }}</p>
        </div>
    </div>
{% endif %}

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
    <!-- Produk -->
    <section class="ppob-card relative overflow-hidden bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500">Produk</p>
                <h3 class="mt-2 text-3xl font-bold text-slate-800">{{ metrics.product_count }}</h3>
            </div>
            <div class="rounded-xl bg-blue-50 p-3 text-blue-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            </div>
        </div>
        <p class="mt-4 text-xs text-slate-500">Total kategori dalam katalog.</p>
    </section>

    <!-- Produk Aktif -->
    <section class="ppob-card relative overflow-hidden bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500">Produk Aktif</p>
                <h3 class="mt-2 text-3xl font-bold text-slate-800">{{ metrics.active_product_count }}</h3>
            </div>
            <div class="rounded-xl bg-emerald-50 p-3 text-emerald-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <p class="mt-4 text-xs text-slate-500">Produk yang saat ini ditampilkan ke pelanggan.</p>
    </section>

    <!-- Transaksi -->
    <section class="ppob-card relative overflow-hidden bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500">Transaksi</p>
                <h3 class="mt-2 text-3xl font-bold text-slate-800">{{ metrics.transaction_count }}</h3>
            </div>
            <div class="rounded-xl bg-amber-50 p-3 text-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
        </div>
        <p class="mt-4 text-xs text-slate-500">Riwayat pembelian tamu dan member.</p>
    </section>

    <!-- Pendapatan -->
    <section class="ppob-card relative overflow-hidden bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500">Pendapatan</p>
                <h3 class="mt-2 text-3xl font-bold text-slate-800">Rp {{ metrics.total_revenue }}</h3>
            </div>
            <div class="rounded-xl bg-purple-50 p-3 text-purple-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <p class="mt-4 text-xs text-slate-500">Akumulasi total dari tabel transaksi.</p>
    </section>
</div>

<section class="ppob-card mt-6 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center justify-between gap-4 p-6 border-b border-slate-100">
        <div>
            <h3 class="text-lg font-bold text-slate-800">Transaksi Terbaru</h3>
            <p class="text-sm text-slate-500 mt-1">Pembayaran terbaru yang tampil di panel admin.</p>
        </div>
        <a href="/admin/transactions" class="inline-flex items-center gap-2 text-sm font-semibold text-sky-600 hover:text-sky-700 bg-sky-50 hover:bg-sky-100 px-4 py-2.5 rounded-xl transition-colors">
            Lihat semua
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
        </a>
    </div>

    <div class="overflow-x-auto p-4">
        <table class="min-w-full text-left text-sm">
            <thead class="text-slate-500 bg-slate-50/80">
                <tr>
                    <th class="px-5 py-4 font-semibold rounded-tl-xl rounded-bl-xl">Invoice</th>
                    <th class="px-5 py-4 font-semibold">Customer</th>
                    <th class="px-5 py-4 font-semibold">Product</th>
                    <th class="px-5 py-4 font-semibold rounded-tr-xl rounded-br-xl">Total</th>
                </tr>
            </thead>
            <tbody>
                {% for transaction in recentTransactions %}
                    <tr class="border-b border-slate-50 last:border-0 hover:bg-slate-50/50 transition-colors">
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-3">
                                <div class="p-2 bg-slate-100 rounded-lg text-slate-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-bold text-slate-700">{{ transaction.invoice_code }}</p>
                                    <p class="text-xs text-slate-500 mt-0.5">{{ transaction.created_at }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-4 font-medium text-slate-700">{{ transaction.customer_name }}</td>
                        <td class="px-5 py-4">
                            <p class="font-medium text-slate-700">{{ transaction.category_name }}</p>
                            <p class="text-xs text-slate-500 mt-0.5">{{ transaction.item_name }}</p>
                        </td>
                        <td class="px-5 py-4 font-bold text-sky-600">Rp {{ transaction.total_price }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-5 py-12 text-center text-slate-500">
                            <div class="flex flex-col items-center justify-center">
                                <div class="p-4 bg-slate-50 rounded-full mb-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                    </svg>
                                </div>
                                <p class="font-medium">Belum ada transaksi</p>
                                <p class="text-xs mt-1">Transaksi terbaru akan muncul di sini.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
