{% extends 'layouts/admin.twig' %}

{% block content %}
{% if databaseError %}
    <div class="mb-6 rounded-3xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700 dark:border-rose-500/40 dark:bg-rose-500/10 dark:text-rose-200">
        Gagal memuat transaksi. {{ databaseError }}
    </div>
{% endif %}

<section class="ppob-card overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
            <thead class="border-b border-slate-200 bg-slate-50/80 text-slate-500 dark:border-slate-800 dark:bg-slate-950/60 dark:text-slate-400">
                <tr>
                    <th class="px-5 py-4 font-medium">Invoice</th>
                    <th class="px-5 py-4 font-medium">Customer</th>
                    <th class="px-5 py-4 font-medium">Product Item</th>
                    <th class="px-5 py-4 font-medium">Total</th>
                    <th class="px-5 py-4 font-medium">Status</th>
                    <th class="px-5 py-4 font-medium">Date</th>
                </tr>
            </thead>
            <tbody>
                {% for transaction in transactions %}
                    <tr class="border-b border-slate-100 last:border-0 dark:border-slate-900">
                        <td class="px-5 py-5 font-semibold">{{ transaction.invoice_code }}</td>
                        <td class="px-5 py-5">
                            <p>{{ transaction.customer_name }}</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400">{{ transaction.customer_email }}</p>
                        </td>
                        <td class="px-5 py-5">
                            <p>{{ transaction.category_name }}</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400">{{ transaction.item_name }}</p>
                        </td>
                        <td class="px-5 py-5 font-semibold text-sky-600 dark:text-sky-300">Rp {{ transaction.total_price }}</td>
                        <td class="px-5 py-5">
                            {% if transaction.status == 'Paid' %}
                                <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20 dark:bg-emerald-500/10 dark:text-emerald-400 dark:ring-emerald-500/20">Paid</span>
                            {% elseif transaction.status == 'Pending' %}
                                <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20 dark:bg-amber-500/10 dark:text-amber-400 dark:ring-amber-500/20">Pending</span>
                            {% else %}
                                <span class="inline-flex items-center rounded-full bg-rose-50 px-2 py-1 text-xs font-medium text-rose-700 ring-1 ring-inset ring-rose-600/20 dark:bg-rose-500/10 dark:text-rose-400 dark:ring-rose-500/20">{{ transaction.status }}</span>
                            {% endif %}
                        </td>
                        <td class="px-5 py-5 text-slate-500 dark:text-slate-400">{{ transaction.created_at }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="px-5 py-10 text-center text-slate-500 dark:text-slate-400">Belum ada transaksi.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
