{% extends 'layouts/admin.twig' %}

{% block content %}
<div class="mb-6">
    <a href="/admin/products/{{ productId }}/items" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-800 transition-colors mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Kembali ke Data Item
    </a>
    <h2 class="text-xl font-bold text-slate-800">{{ title }}</h2>
    <p class="text-sm text-slate-500 mt-1">Produk: {{ product.item_name }} ({{ product.category_name }})</p>
</div>

<form action="{{ submitUrl }}" method="POST" class="space-y-6">
    {% if errors %}
        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 flex gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
                <p class="font-bold">Mohon perbaiki error validasi berikut:</p>
                <ul class="mt-2 list-disc space-y-1 pl-5">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% if databaseError %}
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>Gagal menyimpan item produk. {{ databaseError }}</p>
        </div>
    {% endif %}

    <section class="ppob-card bg-white rounded-2xl shadow-sm border border-slate-100 p-6 grid gap-6 lg:grid-cols-2">
        <div class="lg:col-span-2 border-b border-slate-100 pb-4">
            <h3 class="text-lg font-bold text-slate-800">Data Item</h3>
            <p class="mt-1 text-sm text-slate-500">Masukkan data akun atau informasi detail item yang akan dijual.</p>
        </div>

        <div class="lg:col-span-2">
            <label for="account_data" class="mb-2 block text-sm font-semibold text-slate-700">Detail Item / Data Akun</label>
            <textarea id="account_data" name="account_data" rows="5" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 font-mono" placeholder="Email: user@example.com&#10;Password: secret123" required>{{ form.account_data }}</textarea>
            <p class="mt-2 text-xs text-slate-500">Data ini akan dikirim ke pembeli setelah pembayaran berhasil. Format bebas.</p>
        </div>

        <div class="lg:col-span-2">
            <label for="description" class="mb-2 block text-sm font-semibold text-slate-700">Catatan Tambahan (Opsional)</label>
            <textarea id="description" name="description" rows="3" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20" placeholder="Akun fresh baru dibuat hari ini...">{{ form.description }}</textarea>
            <p class="mt-2 text-xs text-slate-500">Catatan ini akan tampil di detail item untuk pembeli.</p>
        </div>

        <div class="lg:col-span-2">
            <label for="status" class="mb-2 block text-sm font-semibold text-slate-700">Status Item</label>
            <select id="status" name="status" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20" required>
                <option value="available" {% if form.status == 'available' %}selected{% endif %}>Available (Tersedia)</option>
                <option value="checking" {% if form.status == 'checking' %}selected{% endif %}>Checking (Sedang dicek out)</option>
                <option value="sold" {% if form.status == 'sold' %}selected{% endif %}>Sold (Terjual)</option>
            </select>
        </div>
    </section>

    <section class="ppob-card bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <div class="border-b border-slate-100 pb-4 mb-6">
            <h3 class="text-lg font-bold text-slate-800">Screenshot / Gambar Item (Opsional)</h3>
            <p class="mt-1 text-sm text-slate-500">Tambahkan bukti screenshot akun. Maksimal 5 gambar.</p>
        </div>

        <div id="image-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-4">
            {% for image in form.images %}
                <div class="relative group rounded-xl overflow-hidden border border-slate-200 aspect-square image-item">
                    <img src="{{ image }}" class="w-full h-full object-cover">
                    <input type="hidden" name="images[]" value="{{ image }}">
                    <button type="button" class="absolute top-2 right-2 p-1.5 bg-rose-500 text-white rounded-lg opacity-0 group-hover:opacity-100 transition-opacity remove-image" title="Hapus gambar">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            {% endfor %}

            <div id="add-image-btn" class="rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 hover:bg-slate-100 transition-colors aspect-square flex flex-col items-center justify-center cursor-pointer text-slate-500 hover:text-sky-600 hover:border-sky-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
                <span class="text-xs font-medium">Add Image</span>
                <input type="file" id="image-upload" accept="image/jpeg,image/png,image/webp" class="hidden">
            </div>
        </div>
        <p class="text-xs text-slate-500">Format: JPG, PNG, WEBP. Maks 5MB per gambar.</p>
    </section>

    <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
        <a href="/admin/products/{{ productId }}/items" class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl transition-colors">
            Batal
        </a>
        <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-sky-600 hover:bg-sky-700 rounded-xl transition-colors shadow-sm shadow-sky-600/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
            </svg>
            {{ formMode == 'create' ? 'Simpan Item' : 'Perbarui Item' }}
        </button>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const uploadInput = document.getElementById('image-upload');
    const addBtn = document.getElementById('add-image-btn');
    const imageList = document.getElementById('image-list');

    addBtn.addEventListener('click', () => {
        uploadInput.click();
    });

    uploadInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        // Check total images
        const currentImages = document.querySelectorAll('.image-item').length;
        if (currentImages >= 5) {
            alert('Maksimal 5 gambar per item.');
            uploadInput.value = '';
            return;
        }

        const formData = new FormData();
        formData.append('file', file);

        // Add loading state
        const loadingId = 'loading-' + Date.now();
        const loadingHtml = `
            <div id="${loadingId}" class="rounded-xl border border-slate-200 bg-slate-50 aspect-square flex items-center justify-center">
                <svg class="animate-spin h-6 w-6 text-sky-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
        `;
        addBtn.insertAdjacentHTML('beforebegin', loadingHtml);

        try {
            const response = await fetch('/admin/upload/product-item', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();
            
            // Remove loading
            document.getElementById(loadingId).remove();

            if (data.success) {
                const itemHtml = `
                    <div class="relative group rounded-xl overflow-hidden border border-slate-200 aspect-square image-item">
                        <img src="${data.path}" class="w-full h-full object-cover">
                        <input type="hidden" name="images[]" value="${data.path}">
                        <button type="button" class="absolute top-2 right-2 p-1.5 bg-rose-500 text-white rounded-lg opacity-0 group-hover:opacity-100 transition-opacity remove-image" title="Hapus gambar">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                `;
                addBtn.insertAdjacentHTML('beforebegin', itemHtml);
            } else {
                alert(data.error || 'Upload failed');
            }
        } catch (err) {
            document.getElementById(loadingId)?.remove();
            alert('An error occurred while uploading.');
        }

        uploadInput.value = ''; // Reset input
    });

    // Handle remove image
    imageList.addEventListener('click', (e) => {
        const removeBtn = e.target.closest('.remove-image');
        if (removeBtn) {
            if (confirm('Hapus gambar ini?')) {
                removeBtn.closest('.image-item').remove();
            }
        }
    });
});
</script>
{% endblock %}